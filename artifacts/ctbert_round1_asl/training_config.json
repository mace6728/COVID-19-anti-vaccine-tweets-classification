{
  "data_dir": "preprocessed",
  "output_dir": "artifacts/ctbert_round1_asl",
  "metadata_file": "metadata.json",
  "train_file": "train_preprocessed.csv",
  "val_file": "val_preprocessed.csv",
  "text_column": "tweet_clean",
  "model_type": "transformer",
  "pretrained_model": "digitalepidemiologylab/covid-twitter-bert-v2",
  "head_type": "linear",
  "pooling": "cls",
  "multi_sample_dropout": 6,
  "freeze_backbone": false,
  "max_length": 128,
  "vocab_max_size": 30000,
  "vocab_min_freq": 2,
  "embedding_dim": 200,
  "hidden_size": 128,
  "num_layers": 1,
  "attention_heads": 8,
  "dropout": 0.2,
  "batch_size": 8,
  "epochs": 1,
  "learning_rate": 2e-05,
  "weight_decay": 0.01,
  "grad_clip_norm": 1.0,
  "grad_accum_steps": 4,
  "scheduler_factor": 0.5,
  "scheduler_patience": 2,
  "scheduler_min_lr": 1e-06,
  "early_stopping_patience": 5,
  "loss_type": "asl",
  "asl_gamma_neg": 4.0,
  "asl_gamma_pos": 1.0,
  "asl_clip": 0.05,
  "asl_use_pos_weight": true,
  "threshold_start": 0.05,
  "threshold_end": 0.95,
  "threshold_step": 0.05,
  "glove_path": null,
  "freeze_embedding": false,
  "seed": 42,
  "num_workers": 2,
  "device": null
}